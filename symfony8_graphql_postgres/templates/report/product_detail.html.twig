{# templates/report/product_detail.html.twig #}
<div>
  <img src="{{ logo_base64 }}" alt="Logo" width="100">
  <h2 style="font-family: Helvetica;margin-top:-3px;">Products Report</h2>
  <p style="font-family: Helvetica;margin-top:-20px;font-size:10px;">
      As of {{ "now"|date('l, F j, Y') }}
  </p>
  
  <table style="width: 100%; border-collapse: collapse;">
      <thead style="background-color: burlywood;">
        <tr style="border: 1px solid black;">
          <th style="font-size:14px;font-family: Helvetica;">#</th>
          <th style="font-size:14px;font-family: Helvetica;">Description</th>
          <th style="font-size:14px;font-family: Helvetica; width: 90px; text-align: center;">Stocks</th>
          <th style="font-size:14px;font-family: Helvetica;">CostPrice</th>
          <th style="font-size:14px;font-family: Helvetica;">SellPrice</th>
        </tr>      
      </thead>
      <tbody>
          {% for product in products %}
              <tr style="border-bottom: 1px solid #ccc;">
                  <td style="font-size:12px;font-family: Helvetica;">{{ product.id }}</td>
                  <td style="font-size:12px;font-family: Helvetica;">{{ product.descriptions }}</td>
                  <td style="font-size:12px;font-family: Helvetica; text-align: center;">{{ product.qty }}</td>
                  <td style="font-size:12px;font-family: Helvetica;">${{ product.costprice|number_format(2) }}</td>
                  <td style="font-size:12px;font-family: Helvetica;">${{ product.sellprice|number_format(2) }}</td>
              </tr>
          {% endfor %}
      </tbody>
  </table>

  <script type="text/php">
      if (isset($pdf)) {
          $text = "Page {PAGE_NUM} of {PAGE_COUNT}";
          $font = $fontMetrics->get_font("helvetica", "bold");
          $size = 10;
          $color = array(0,0,0);
          $x = 250; 
          $y = $pdf->get_height() - 35;
          $pdf->page_text($x, $y, $text, $font, $size, $color);
      }
  </script>
</div>
